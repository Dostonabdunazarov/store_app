# ─── Postgres ───────────────────────────────────────────────
POSTGRES_USER=hypex
POSTGRES_PASSWORD=hypex_dev_pw
POSTGRES_DB=hypex
# Порт Postgres на хосте (локально). 5432/5433 часто заняты — используем 5440.
POSTGRES_PORT=5440

# ─── Прод-секреты (нужны только на сервере, docker-compose.prod.yml) ───
# Надёжный пароль БД и JWT-ключ (минимум 32 символа).
#   openssl rand -base64 48
# POSTGRES_PASSWORD=<strong-random>
# JWT_KEY=<random-32+-chars>
# Origin фронтенда для CORS (по умолчанию https://store.hypex.site).
# CORS_ALLOWED_ORIGIN=https://store.hypex.site
